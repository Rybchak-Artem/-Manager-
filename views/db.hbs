<style>
:root {
    background: #0B130E;  
    color: #ffffff;           
    color-scheme: dark;  
}

html, body {
    height: 100% !important;
    margin: 0;
    }

body {
    background-color: #0B130E;  
    margin-top: 0px;
    min-height: 100vh;
    background-color: `#ff003737;
    font-family:'Calibri', sans-serif;
}

table {
    width: 1000px;
    margin: 50px auto;
    border-collapse: collapse;
    background: #0a0a1a;
    backdrop-filter: blur(10px);         
    border-radius: 15px;
    overflow: hidden;
    border: 1px solid rgb(255, 255, 255);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    margin-top: 100px;
}

table th {
    background: #2D4236;
    color: #ffffff;
    padding: 14px;
    text-transform: uppercase;
    font-size: 20px;
    text-align: center;
    letter-spacing: 1px;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
}

table td {
    background: #14221A;
    padding: 12px 15px;
    color: #ffffff;

    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    font-size: 20px;
}

table tr:hover {
    background: rgba(255, 255, 255, 0.1);
    transition: 0.3s;
}

.btn-back {
    position: absolute;
    top: 20px;
    left: 40px;
    text-decoration: none;
    font-size: 50px;
    color: #22C55E;
}

.btn-delete {
    color: #ff4b2b;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    background-color: rgba(0, 0, 0, 0.5);
    border: 1px solid #ff4b2b;
}

.btn-edit, .btn-delete {
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 6px;
    font-weight: bold;
    font-size: 14px;
    transition: 0.3s;
}

.btn-edit {
    color: #4facfe;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    background-color: rgba(0, 0, 0, 0.5);
    border: 1px solid #4facfe;
}

.btn-edit:hover {
    background: #4facfe;
    color: #fff;
}

</style>
